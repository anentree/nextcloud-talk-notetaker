# Nextcloud connection
NEXTCLOUD_URL=https://your-nextcloud.example.com
NEXTCLOUD_USER=ai-notetaker
NEXTCLOUD_PASSWORD=app-password-here

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# SMTP (for emailing notes)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=ai-notetaker@your-domain.com
# Optional — leave blank for unauthenticated local SMTP
SMTP_USER=
SMTP_PASSWORD=

# Service settings
POLL_INTERVAL_SECONDS=10
NOTES_FOLDER=/Talk/Notes
AUDIO_DIR=/tmp/notetaker-audio
